# Copy to .env and fill in your own values. NEVER commit the real .env.

# RPC endpoint for the target network (e.g. Alchemy/Infura Sepolia URL)
SEPOLIA_RPC_URL=

# Deployer private key — KEEP SECRET. Used by forge script --private-key.
PRIVATE_KEY=

# Etherscan API key, used to verify the contract source on deploy.
ETHERSCAN_API_KEY=

# RPC endpoint for Ethereum mainnet (used when deploying the factory for real).
MAINNET_RPC_URL=

# Fee-recipient wallet for the CoffeeFactory (your public 0x... ADDRESS, never
# a private key). Leave empty to default to the deployer.
PLATFORM_OWNER=
